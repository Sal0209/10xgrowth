OPENAI_API_KEY = YOUR-API-KEY
# NOTE: Node.js has trouble resolving Supabase IPv6 hostnames like db.himfnzevkhqolbofivqb.supabase.co
# You MUST use the "Transaction Pooler" (IPv4) connection string from your Supabase Dashboard.
# It usually looks like this: postgresql://postgres.[PROJECTID]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

DATABASE_URL="postgresql://postgres.[PROJECTID]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres"

